{
  "name": "oatmeal",
  "productName": "Oatmeal",
  "version": "0.1.0",
  "description": "Local-first meeting notetaker. Your meetings never leave your Mac.",
  "private": true,
  "main": "dist-electron/main.js",
  "author": "Sankalp Damani",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "doctor": "bash scripts/doctor.sh",
    "dev": "vite",
    "build": "npm run build:native && tsc -p tsconfig.electron.json --noEmit && vite build",
    "build:native": "bash scripts/build-native.sh",
    "build:whisper": "bash scripts/build-whisper.sh",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.json --noEmit",
    "dist": "npm run build && electron-builder --mac --arm64",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.sankalp.oatmeal",
    "productName": "Oatmeal",
    "directories": { "output": "release" },
    "files": ["dist/**", "dist-electron/**"],
    "afterPack": "scripts/after-pack.cjs",
    "extraResources": [
      { "from": "resources/bin", "to": "bin" }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Oatmeal transcribes your side of meetings from the microphone. Audio never leaves your Mac.",
        "NSAudioCaptureUsageDescription": "Oatmeal captures system audio to transcribe the other side of meetings. Audio never leaves your Mac."
      }
    }
  }
}
